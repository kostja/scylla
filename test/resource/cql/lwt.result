  | [APPLIED] | B |
  +-----------+---+
  | true      | 0 |
  +-----------+---+
select * from lwt allow filtering;
  +---+---+
  | A | B |
  +---+---+
  | 1 | 2 |
  +---+---+
drop table lwt;
  OK
