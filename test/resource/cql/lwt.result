  | A | C  | LISTINT |  MAPINT  | SETINT |
  +---+----+---------+----------+--------+
  | 1 | 12 | [1]     | map[1:1] | [1]    |
  +---+----+---------+----------+--------+
update lwt set c=13 where a = 1 if mapint[1] = null;
  +-----------+----------+
  | [APPLIED] |  MAPINT  |
  +-----------+----------+
  | false     | map[1:1] |
  +-----------+----------+
select * from lwt allow filtering;
